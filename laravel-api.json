{
  "info": {
    "name": "API Réseau Social",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Inscription",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "url": "http://localhost/api/register",
        "body": {
          "mode": "raw",
          "raw": "{\n    \"name\": \"Jean Dupont\",\n    \"email\": \"jean@example.com\",\n    \"password\": \"password123\",\n    \"password_confirmation\": \"password123\"\n}"
        }
      }
    },
    {
      "name": "2. Connexion",
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "if (pm.response.code === 200) {",
            "    var jsonData = pm.response.json();",
            "    pm.environment.set(\"token\", jsonData.token);",
            "}"
          ]
        }
      }],
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "url": "http://localhost/api/login",
        "body": {
          "mode": "raw",
          "raw": "{\n    \"email\": \"jean@example.com\",\n    \"password\": \"password123\"\n}"
        }
      }
    },
    {
      "name": "3. Voir publications",
      "request": {
        "method": "GET",
        "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
        "url": "http://localhost/api/publications"
      }
    },
    {
      "name": "4. Créer publication",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ],
        "url": "http://localhost/api/publications",
        "body": {
          "mode": "raw",
          "raw": "{\n    \"message\": \"Ma publication depuis Postman\"\n}"
        }
      }
    },
    {
      "name": "5. Ajouter commentaire",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ],
        "url": "http://localhost/api/commentaires",
        "body": {
          "mode": "raw",
          "raw": "{\n    \"publication_id\": 1,\n    \"contenu\": \"Super publication !\"\n}"
        }
      }
    },
    {
      "name": "6. Ajouter like",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ],
        "url": "http://localhost/api/likes",
        "body": {
          "mode": "raw",
          "raw": "{\n    \"publication_id\": 1\n}"
        }
      }
    },
    {
      "name": "7. Voir likes",
      "request": {
        "method": "GET",
        "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
        "url": "http://localhost/api/likes/1"
      }
    },
    {
      "name": "8. Voir commentaires",
      "request": {
        "method": "GET",
        "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
        "url": "http://localhost/api/commentaires/1"
      }
    },
    {
      "name": "9. Voir utilisateur",
      "request": {
        "method": "GET",
        "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
        "url": "http://localhost/api/user"
      }
    },
    {
      "name": "10. Déconnexion",
      "request": {
        "method": "POST",
        "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
        "url": "http://localhost/api/logout"
      }
    }
  ]
}
